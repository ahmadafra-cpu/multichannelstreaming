# Copy to .env (local/Docker) or set these as Environment Variables in the Vercel dashboard.

# REQUIRED in production / on Vercel: a long random string. Encrypts the session token
# and signs stream URLs. MUST be stable across restarts & instances, or users get logged
# out on every serverless cold start. Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Streaming mode:
#   direct = browser connects straight to the camera host (REQUIRED on Vercel — serverless
#            can't hold a long stream open). Note: uses the camera host's port (22001), which
#            some firewalled networks block.
#   proxy  = stream is proxied through this app on 443 (firewall-proof). Needs a long-running
#            host (Docker/VM/Render/Railway/Fly/Cloud Run) — NOT Vercel.
# Auto-defaults to "direct" on Vercel, "proxy" otherwise. Override here if needed.
# STREAM_MODE=direct

# Who may embed this app in an iframe (CSP frame-ancestors). The Trax app runs on zendu.one.
CSP_FRAME_ANCESTORS='self' https://*.zendu.one https://*.zenduit.com

# Upstreams (defaults match the Trax/Zenduit dev service).
ONE_SERVICE_URL=https://one-service.zenduit.com/api/
STREAM_HOST=streamax-api.zenduit.com
STREAM_PORT=22001

# Camera device types to list (comma-separated).
CAMERA_DEVICE_TYPES=StreamMax

# Rate limits (best-effort per-instance on serverless; use Upstash for cross-instance).
API_RATE_MAX=600     # requests/min/IP across /api and /auth/me
LOGIN_RATE_MAX=20    # sign-in attempts / 15 min / (IP + username)

# --- Long-running host only (Docker / VM) ---
PORT=8080
TRUST_PROXY=1

# --- Caddy TLS profile (docker compose --profile tls) ---
# DOMAIN=cameras.example.com
# ACME_EMAIL=you@example.com
# APP_PORT=8080
